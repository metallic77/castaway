diff -ruN '--exclude=obj' '--exclude=castaway' castaway/sdl/main.c castaway-fixed/sdl/main.c
--- castaway/sdl/main.c	2026-06-11 12:26:34.738782119 +0000
+++ castaway-fixed/sdl/main.c	2026-06-11 12:42:16.024056932 +0000
@@ -18,7 +18,154 @@
